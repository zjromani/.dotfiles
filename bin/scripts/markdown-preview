#!/bin/bash
# markdown-preview: smart markdown preview from any tmux context
#
# From nvim:          triggers :MarkdownPreview in the current buffer
# From Claude/shell:  opens the most recent plan file in a new nvim split + preview

PANE_ID="${1:-}"

# Detect what's running in the calling pane
if [[ -n "$PANE_ID" ]]; then
  PANE_CMD=$(tmux display-message -t "$PANE_ID" -p '#{pane_current_command}' 2>/dev/null)
else
  PANE_CMD=$(tmux display-message -p '#{pane_current_command}' 2>/dev/null)
fi

if [[ "$PANE_CMD" == "nvim" || "$PANE_CMD" == "vim" ]]; then
  # Already in nvim — trigger MarkdownPreview on the current buffer
  if [[ -n "$PANE_ID" ]]; then
    tmux send-keys -t "$PANE_ID" ":MarkdownPreview" Enter
  else
    tmux send-keys ":MarkdownPreview" Enter
  fi
else
  # Not in nvim (Claude, shell, etc.) — open the most recent plan file
  PLAN_FILE=$(ls -t "$HOME/.claude/plans/"*.md 2>/dev/null | head -1)
  if [[ -z "$PLAN_FILE" ]]; then
    echo "No plan files found in ~/.claude/plans/" >&2
    exit 1
  fi

  # Open nvim in a new right-side split with MarkdownPreview auto-triggered
  if [[ -n "$PANE_ID" ]]; then
    tmux split-window -h -t "$PANE_ID" -c "$HOME" "nvim '$PLAN_FILE' -c 'MarkdownPreview'"
  else
    tmux split-window -h -c "$HOME" "nvim '$PLAN_FILE' -c 'MarkdownPreview'"
  fi
fi

# Give the preview time to open in Chrome
sleep 2

# Snap iTerm2 to left half, Chrome to right half
osascript <<'EOF'
tell application "System Events"
  set screenWidth to item 1 of (size of first desktop)
  set screenHeight to item 2 of (size of first desktop)
end tell

set halfWidth to (screenWidth / 2) as integer

tell application "iTerm2"
  set bounds of front window to {0, 0, halfWidth, screenHeight}
end tell

delay 0.2

if application "Google Chrome" is running then
  tell application "Google Chrome"
    set bounds of front window to {halfWidth, 0, screenWidth, screenHeight}
  end tell
end if
EOF
