#! /usr/bin/env bash

if [[ "$1" == "--worktrees" ]]; then
  extra_roots=()
  if [[ -n "$SESSIONIZER_EXTRA_DIRS" ]]; then
    IFS=' ' read -r -a extra_roots <<< "$SESSIONIZER_EXTRA_DIRS"
  fi

  shopt -s nullglob
  home_dirs=(~/*/)
  shopt -u nullglob
  search_dirs=("${home_dirs[@]}" ~/.dotfiles ~/me/*/ ~/flights/*/)
  for root in "${extra_roots[@]}"; do
    search_dirs+=("$root"/*/)
  done
  shopt -u nullglob

  worktree_paths=()
  for dir in "${search_dirs[@]%/}"; do
    # Find git repos one level deep
    for repo in "$dir"/*/; do
      [[ -d "$repo/.git" ]] || continue
      while IFS= read -r line; do
        [[ "$line" == worktree* ]] && worktree_paths+=("${line#worktree }")
      done < <(git -C "$repo" worktree list --porcelain 2>/dev/null)
    done
    # Also check if dir itself is a git repo
    if [[ -d "$dir/.git" ]]; then
      while IFS= read -r line; do
        [[ "$line" == worktree* ]] && worktree_paths+=("${line#worktree }")
      done < <(git -C "$dir" worktree list --porcelain 2>/dev/null)
    fi
  done

  selected=$(printf '%s\n' "${worktree_paths[@]}" | sort -u | fzf --no-sort --tiebreak=index --height=40%)
  [ -z "$selected" ] && exit 0

  # Session name: <repo>_<branch> to avoid collisions
  repo_name=$(basename "$(git -C "$selected" rev-parse --show-toplevel 2>/dev/null)")
  branch=$(git -C "$selected" rev-parse --abbrev-ref HEAD 2>/dev/null | tr '/' '_')
  session_name="${repo_name}_${branch}"
  session_name=$(echo "$session_name" | tr . _)

  if ! tmux has-session -t "$session_name" 2>/dev/null; then
    tmux new-session -s "$session_name" -c "$selected" -d
  fi

  tmux switch-client -t "$session_name"
  exit 0
fi

extra_roots=()
if [[ -n "$SESSIONIZER_EXTRA_DIRS" ]]; then
  IFS=' ' read -r -a extra_roots <<< "$SESSIONIZER_EXTRA_DIRS"
fi

CACHE_FILE="${TMPDIR:-/tmp}/tmux-sessionizer-dirs-$USER"

_build_dirs() {
  shopt -s nullglob
  local home_dirs=(~/*/)
  local me_dirs=(~/me/*/)
  local flights_dirs=(~/flights/*/)
  local extra_dirs=()
  for root in "${extra_roots[@]}"; do
    local root_dirs=("$root"/*/)
    extra_dirs+=("${root_dirs[@]}")
  done
  shopt -u nullglob
  printf '%s\n' "${home_dirs[@]%/}" ~/.dotfiles "${me_dirs[@]%/}" "${flights_dirs[@]%/}" "${extra_dirs[@]%/}" \
    | grep -vE "/(Downloads|Documents|Music|Movies|Pictures|Desktop|Library|Public|Applications|Dropbox|\.Trash)"
}

# Seed cache on first run; always refresh in background for next invocation
if [[ ! -f "$CACHE_FILE" ]]; then
  _build_dirs > "$CACHE_FILE"
fi
{ _build_dirs > "$CACHE_FILE.tmp" && mv "$CACHE_FILE.tmp" "$CACHE_FILE"; } &>/dev/null &
disown

session=$(
    {
        # Active sessions first for quick navigation
        tmux list-sessions -F "#{session_name}" 2>/dev/null | grep -vE '^[0-9]+$'
        # Short aliases for quick navigation (type the alias name to jump directly)
        echo "flights"
        # Directories from cache
        cat "$CACHE_FILE"
    } | fzf --no-sort --tiebreak=index --height=40%
)

[ -z "$session" ] && exit 0

# Resolve short aliases to full paths
case "$session" in
  flights) session="$HOME/flights" ;;
esac

session_name=$(basename "$session")
for root in "${extra_roots[@]}"; do
  if [[ "$session" == "$root"/* ]]; then
    session_name="$(basename "$root")_$(basename "$session")"
    break
  fi
done
session_name=$(echo "$session_name" | tr . _)

if ! tmux has-session -t "$session_name" 2>/dev/null; then
    tmux new-session -s "$session_name" -c "$session" -d
fi

tmux switch-client -t "$session_name"
