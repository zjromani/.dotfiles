#!/bin/bash
set -e

FILE="$HOME/flights/daily-brief/$(date +%Y-%m-%d)-brief.md"

mkdir -p "$HOME/flights/daily-brief"
[ -f "$FILE" ] || touch "$FILE"

# Switch to existing daily-brief session, or create one and open nvim
if tmux has-session -t daily-brief 2>/dev/null; then
  tmux switch-client -t daily-brief
else
  tmux new-session -d -s daily-brief -c "$HOME/flights/daily-brief"
  tmux send-keys -t daily-brief "nvim + '$FILE'" Enter
  tmux switch-client -t daily-brief
fi
