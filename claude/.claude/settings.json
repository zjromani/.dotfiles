{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git remote*)",
      "Bash(git fetch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git restore*)",
      "Bash(git merge*)",
      "Bash(git pull*)",
      "Bash(git reset*)",
      "Bash(git tag*)",
      "Bash(git stash*)",
      "Bash(git clean*)",
      "Bash(git rm*)",
      "Bash(git mv*)",
      "Bash(git config*)",
      "Bash(git submodule*)",
      "Bash(git worktree*)",
      "Bash(git cherry-pick*)",
      "Bash(git blame*)",
      "Bash(git bisect*)",
      "Bash(git push*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr diff*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh repo view*)",
      "Bash(gh repo list*)",
      "Bash(gh run view*)",
      "Bash(gh run list*)",
      "Bash(gh run watch*)",
      "Bash(gh release view*)",
      "Bash(gh release list*)",
      "Bash(gh search *)",
      "Bash(gh api *)",
      "Bash(gh status*)",
      "Bash(gh auth status*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(less*)",
      "Bash(more*)",
      "Bash(ls*)",
      "Bash(tree*)",
      "Bash(file*)",
      "Bash(stat*)",
      "Bash(wc*)",
      "Bash(sort*)",
      "Bash(uniq*)",
      "Bash(cut*)",
      "Bash(awk*)",
      "Bash(sed*)",
      "Bash(cd *)",
      "Bash(echo *)",
      "Bash(pwd*)",
      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run build*)",
      "Bash(npm run lint*)",
      "Bash(npx tsc --noEmit*)",
      "Bash(bundle exec rspec*)",
      "Bash(bundle exec rubocop*)",
      "Bash(rails routes*)",
      "Bash(kubectl get*)",
      "Bash(kubectl describe*)",
      "Bash(kubectl logs*)",
      "Bash(terraform plan*)",
      "Bash(terraform validate*)",
      "Bash(terraform fmt*)",
      "Bash(heroku logs*)",
      "Bash(heroku ps*)",
      "Bash(heroku config*)",
      "WebSearch",
      "WebFetch",
      "mcp__*"
    ],
    "deny": [
      "Bash(git rebase*)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a'; SESSION=$(tmux display-message -p -t \"$TMUX_PANE\" '#S / #W' 2>/dev/null || echo 'terminal'); osascript -e \"display notification \\\"Claude finished\\\" with title \\\"Claude Code\\\" subtitle \\\"$SESSION\\\"\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a'; SESSION=$(tmux display-message -p -t \"$TMUX_PANE\" '#S / #W' 2>/dev/null || echo 'terminal'); osascript -e \"display notification \\\"Claude needs input\\\" with title \\\"Claude Code\\\" subtitle \\\"$SESSION\\\"\""
          }
        ]
      }
    ]
  },
  "effortLevel": "medium"
}
